# ─────────────────────────────────────────────────────────────
# Localia — Variables de entorno (plantilla)
# Copia este archivo a .env.local (desarrollo) y configura los MISMOS valores
# en Vercel → Project → Settings → Environment Variables (producción).
# NUNCA subas .env.local al repositorio ni hardcodees claves en el código.
# ─────────────────────────────────────────────────────────────

# ── Supabase (BASE DE DATOS + AUTH + STORAGE) — YA EN USO, OBLIGATORIO ──
# Dónde: app.supabase.com → tu proyecto → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # SECRETO — solo servidor, nunca con prefijo NEXT_PUBLIC_
# Conexión directa (migraciones/Drizzle), opcional:
DATABASE_URL=

# ── Stripe (PAGOS + MARKETPLACE CONNECT) — YA EN USO / AMPLIADO ──
# Dónde: dashboard.stripe.com → Developers → API keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY= # pk_test_... (o pk_live_...)
STRIPE_SECRET_KEY=                  # sk_test_... (o sk_live_...) — SECRETO
# Webhook: dashboard.stripe.com → Developers → Webhooks → endpoint a /api/payments/webhook
STRIPE_WEBHOOK_SECRET=              # whsec_...
# Stripe Connect: actívalo en dashboard.stripe.com → Connect → Get started
# (no requiere variable extra; usa STRIPE_SECRET_KEY)

# ── Resend (EMAIL TRANSACCIONAL) — YA EN USO ──
# Dónde: resend.com → API Keys. Verifica el dominio del remitente (pedidos@localia.es).
RESEND_API_KEY=

# ── ENVÍOS multi-transportista (SEUR/MRW/GLS/DHL/Correos vía Shippo) — OPCIONAL ──
# Dónde: goshippo.com → Settings → API. Activa cálculo de tarifas y tracking real.
# Sin esta clave, el envío es "manual" (precio fijo por producto + tracking a mano).
SHIPPO_API_KEY=
# Alternativas (implementar provider en lib/shipping si se prefiere):
# EASYPOST_API_KEY=
# SHIPSTATION_API_KEY=
# SHIPSTATION_API_SECRET=

# ── MAPAS — el mapa usa CARTO/OpenStreetMap (Leaflet), SIN clave. Opcionales: ──
# NEXT_PUBLIC_MAPBOX_TOKEN=         # solo si se vuelve a Mapbox (ya NO es necesario)
# GEOCODIO_API_KEY=                 # geocoding de direcciones (geocod.io)

# ── VERIFICACIÓN DE IDENTIDAD (KYC vendedores) — OPCIONAL ──
# Stripe Identity va incluido con Connect (Express hace el KYC). Alternativas:
# ONFIDO_API_TOKEN=
# VERIFF_API_KEY=

# ── NOTIFICACIONES — OPCIONAL ──
# TWILIO_ACCOUNT_SID=               # SMS (twilio.com)
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=
# NEXT_PUBLIC_ONESIGNAL_APP_ID=     # push web/móvil (onesignal.com)
# ONESIGNAL_REST_API_KEY=

# ── BÚSQUEDA — OPCIONAL (hoy se usa Postgres FTS de Supabase) ──
# NEXT_PUBLIC_ALGOLIA_APP_ID=
# ALGOLIA_ADMIN_KEY=
# NEXT_PUBLIC_ALGOLIA_SEARCH_KEY=
# MEILISEARCH_HOST=                 # alternativa open-source
# MEILISEARCH_API_KEY=

# ── SOPORTE AL CLIENTE — OPCIONAL ──
# NEXT_PUBLIC_CRISP_WEBSITE_ID=     # chat en vivo (crisp.chat)
# NEXT_PUBLIC_INTERCOM_APP_ID=

# ── ANALÍTICA — OPCIONAL (Vercel Analytics + Speed Insights ya activos) ──
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=
# NEXT_PUBLIC_MIXPANEL_TOKEN=

# ── SEGURIDAD / ANTIFRAUDE — OPCIONAL ──
# Cloudflare: se configura a nivel de DNS/proxy, no necesita variable de app.
# Stripe Radar: incluido con Stripe (se gestiona en el dashboard de Stripe).
# NEXT_PUBLIC_RECAPTCHA_SITE_KEY=   # google.com/recaptcha (v3)
# RECAPTCHA_SECRET_KEY=

# ── RATE LIMITING DISTRIBUIDO — OPCIONAL (recomendado para login/registro) ──
# Vercel KV o Upstash Redis (upstash.com)
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
